PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=postgresql://127.0.0.1:5432/butcher_shop

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# AWS S3 storage (media uploads). Leave blank to use local uploads + temporary Unsplash fallbacks for empty URLs.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# When S3 is not fully configured, the Media collection fills missing image URLs with relevant Unsplash images.
# Set to true after S3 is working if you need to read media docs with empty URLs unchanged (rare).
# MEDIA_DISABLE_UNSPLASH_FALLBACK=false
