PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=postgresql://127.0.0.1:5432/butcher_shop

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# AWS S3 storage (media uploads). Leave blank to use local uploads + temporary Unsplash fallbacks for empty URLs.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Disable all Media URL rewrites to online placeholders (empty + ephemeral `/api/media`).
# MEDIA_DISABLE_UNSPLASH_FALLBACK=false

# When S3 is not fully configured, the Media collection fills missing image URLs with online placeholders.
# On Render/Vercel/Railway prod, relative `/api/media/...` URLs are also swapped (ephemeral disk — files 404 after deploy).
# Set to true to keep relative URLs from the API (e.g. persistent VPS with local uploads).
# MEDIA_KEEP_LOCAL_URLS=false
